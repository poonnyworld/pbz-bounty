# =============================================================================
# ⚠️  ป้องกันคะแนน Honor Point หาย — อ่านก่อนรัน
# =============================================================================
# - รันบนเครื่อง Local (Mac): ใช้ DB สำหรับทดสอบเท่านั้น (ชื่ออื่น เช่น honorbot_test)
#   ห้ามใช้ MONGO_URI ชี้ไปที่ DB จริงบน VPS ตอนรัน Local
# - รันบน VPS (production): ใช้ MONGO_URI ที่ชี้ไปที่ MongoDB จริง
# =============================================================================

# Discord – โทเค็นของบอทนี้
DISCORD_TOKEN=your_bot_token_here

# MongoDB
# Local (ทดสอบ): ใช้ DB แยก เช่น mongodb://127.0.0.1:27017/honorbot_test
# VPS (จริง):    ใช้ DB จริง   เช่น mongodb://127.0.0.1:27017/honorbot
MONGO_URI=mongodb://127.0.0.1:27017/honorbot_test

# Bounty Board channel IDs
BOUNTY_HUB_CHANNEL_ID=
BOUNTY_FORUM_CHANNEL_ID=
BOUNTY_SHOWCASE_CHANNEL_ID=
BOUNTY_ADMIN_CHANNEL_ID=

# Optional
# BOUNTY_MAX_POINTS=100
# CLIENT_ID=
# GUILD_ID=
